# Copy this file to .env and fill in all values before running docker compose

# ── PostgreSQL (app) ──────────────────────────────────────────────────────────
MANAGER_DB_PASSWORD=change_me_strong_password

# ── PostgreSQL (Keycloak) ─────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD=change_me_strong_password

# ── Keycloak admin ────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_password

# ── Encryption key for channel tokens at rest (AES-256, base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# TUNNEL_TOKEN is used by cloudflared when using the newer token-based auth.
# Alternatively use credentials.json file — see infra/cloudflare/config.yml
CLOUDFLARE_TUNNEL_TOKEN=

# ── Optional: override Ollama host if not running on the Docker host ──────────
# OLLAMA_BASE_URL=http://host-gateway:11434
