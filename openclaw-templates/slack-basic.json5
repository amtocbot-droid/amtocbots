// OpenClaw instance template — Slack channel
{
  identity: {
    name: "{{INSTANCE_NAME}}",
    theme: "helpful assistant",
    emoji: "🤖",
  },
  agent: {
    workspace: "/root/.openclaw/workspace",
    model: {
      primary: "{{MODEL}}",
    },
  },
  channels: {
    slack: {
      appToken: "{{SLACK_APP_TOKEN}}",      // xapp-...
      botToken: "{{SLACK_BOT_TOKEN}}",      // xoxb-...
      allowChannels: {{SLACK_ALLOW_CHANNELS}},  // array of channel IDs
    },
  },
  gateway: {
    port: 18789,
    auth: {
      tokens: ["{{API_BEARER_TOKEN}}"],
    },
  },
}
