// OpenClaw instance template — Telegram channel
// Generated by AmtocBots Manager. Edit via the UI, not directly.
{
  identity: {
    name: "{{INSTANCE_NAME}}",
    theme: "helpful assistant",
    emoji: "🤖",
  },
  agent: {
    workspace: "/root/.openclaw/workspace",
    model: {
      primary: "{{MODEL}}",
    },
  },
  channels: {
    telegram: {
      token: "{{TELEGRAM_BOT_TOKEN}}",
      allowFrom: {{TELEGRAM_ALLOW_FROM}},  // array of user IDs or group IDs
    },
  },
  gateway: {
    port: 18789,
    auth: {
      tokens: ["{{API_BEARER_TOKEN}}"],
    },
  },
}
